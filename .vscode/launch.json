{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug VantisOS Kernel",
      "cargo": {
        "args": [
          "build",
          "--package=vantis-kernel",
          "--bin=vantis-kernel"
        ],
        "filter": {
          "name": "vantis-kernel",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "cargo: build vantis-kernel",
      "env": {
        "RUST_LOG": "debug"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug Unit Tests",
      "cargo": {
        "args": [
          "test",
          "--no-run",
          "--package=vantis-kernel"
        ],
        "filter": {
          "name": "vantis-kernel",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "cargo: test vantis-kernel (no-run)"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug Current Test",
      "cargo": {
        "args": [
          "test",
          "--no-run",
          "--lib"
        ]
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    }
  ]
}
