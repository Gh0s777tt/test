name: 🔄 Operation Bifrost (GitLab Mirror)

on:
  push:
    branches: [ "**" ]  # Uruchom na KAŻDEJ gałęzi
  delete:               # Uruchom, gdy usuniesz gałąź
  workflow_dispatch:    # Pozwól na ręczne uruchomienie przyciskiem

jobs:
  to-gitlab:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0 # KRYTYCZNE: Pobierz całą historię, nie tylko ostatni commit

      - name: Push to GitLab
        uses: pixta-dev/repository-mirroring-action@v1
        with:
          target_repo_url:
            https://gitlab.com/${{ secrets.GITLAB_USERNAME }}/VantisOS.git
          ssh_private_key: "" # Zostaw puste, używamy tokena
          ssh_username: ${{ secrets.GITLAB_USERNAME }}
          # Token wkładamy w URL w formacie: https://oauth2:TOKEN@gitlab.com/...
          target_repo_token: ${{ secrets.GITLAB_TOKEN }} 
